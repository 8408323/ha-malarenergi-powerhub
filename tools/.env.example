# Copy to tools/.env and adjust for your network. tools/.env is gitignored.
#
# IP of the phone running the Mälarenergi app (traffic source for mitmproxy).
# Use `ip addr` on Linux/macOS or `ipconfig` on Windows to find it.
CAPTURE_PHONE_IP=192.168.1.x

# IP of the PowerHub device on the LAN. Optional — only needed if you also
# want to capture direct device traffic (the PowerHub phones home to the
# Bitvis cloud; there is no useful local API).
CAPTURE_DEVICE_IP=192.168.1.x

# Set to 1 to also capture Firebase/Google API traffic.
# Firebase uses certificate pinning, so these calls often fail through
# mitmproxy. Only enable if you have a pinning-bypass strategy (e.g. a
# patched APK). Default: 0.
CAPTURE_FIREBASE=0
